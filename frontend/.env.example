# Backend API (browser calls this URL; use full URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical site URL for metadata, sitemap, and structured data (defaults to https://phish-check.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://phish-check.vercel.app

# Optional: base URL in “Share result” copy (default https://phish-check.vercel.app)
# NEXT_PUBLIC_SHARE_APP_URL=https://your-domain.com
