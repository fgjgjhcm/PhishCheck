# OpenAI API key (required for /analyze)
OPENAI_API_KEY=sk-...

# Optional: model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# CORS: comma-separated origins (default: http://localhost:3000)
# Production: include your Vercel URL, e.g. https://my-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000
